# CML (Cisco Modeling Labs) Instance Configuration
# Copy this file to .env and fill in your values
CML_URL=https://your-cml-instance.example.com
CML_USERNAME=your_username
CML_PASSWORD=your_password
CML_LAB_NAME=isp-network-deployment
CML_VERIFY_CERT=false
CML_API_BASE=${CML_URL}/api/v2

# Device Credentials (all deployed devices)
DEVICE_USERNAME=your_device_username
DEVICE_PASSWORD=your_device_password
DEVICE_SSH_ENABLED=true
DEVICE_SSH_PORT=22
